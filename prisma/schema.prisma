generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String                   @id @default(cuid())
  email           String                   @unique
  name            String?
  passwordHash    String
  role            Role                     @default(STUDENT)
  status          UserStatus               @default(PENDING)
  emailVerifiedAt DateTime?
  approvedAt      DateTime?
  approvedById    String?
  submissions     Submission[]
  pages           Page[]                   @relation("PageAuthor")
  verifyToken     EmailVerificationToken?
  passwordResets  PasswordResetToken[]
  createdAt       DateTime                 @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum Role {
  STUDENT
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model Submission {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageSlug      String
  url           String
  status        SubmissionStatus @default(PENDING)
  feedback      String?
  attemptNumber Int              @default(1)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId, pageSlug, attemptNumber])
  @@index([userId])
  @@index([pageSlug])
}

enum SubmissionStatus {
  PENDING
  PASS
  FAIL
}

model Page {
  id               String     @id @default(cuid())
  slug             String     @unique
  title            String
  description      String?
  order            Int        @default(0)
  status           PageStatus @default(DRAFT)
  contentHtml      String
  assignmentPrompt String?
  authorId         String
  author           User       @relation("PageAuthor", fields: [authorId], references: [id])
  categoryId       String?
  category         Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags             Tag[]      @relation("PageTags")
  publishedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status, order])
  @@index([categoryId])
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  pages     Page[]
  createdAt DateTime @default(now())
}

model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  pages     Page[]   @relation("PageTags")
  createdAt DateTime @default(now())
}

enum PageStatus {
  DRAFT
  PUBLISHED
}
