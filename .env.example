# --- Database (Postgres) ---
# Local dev: postgresql://user:pass@localhost:5432/hagebook?schema=public
# Prod (Neon): use the *pooled* connection string here.
DATABASE_URL=""

# Prod-only: Neon *direct* connection string (no pooling). Used for prisma migrate deploy.
# Leave empty in local dev — falls back to DATABASE_URL.
DIRECT_URL=""

# --- NextAuth ---
# openssl rand -base64 32
AUTH_SECRET=""
# Local: http://localhost:3000 ; Prod: https://your.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# --- Bootstrap ---
# Email that auto-becomes ADMIN + APPROVED + emailVerified on register.
BOOTSTRAP_ADMIN_EMAIL=""

# --- Email (Lark SMTP) ---
SMTP_HOST="smtp.larksuite.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="hello@hagegames.com"
SMTP_PASS=""
EMAIL_FROM="hagebook <hello@hagegames.com>"

# --- Image storage (Vercel Blob) ---
# Vercel dashboard → Storage → Blob → create store → copy token.
BLOB_READ_WRITE_TOKEN=""
